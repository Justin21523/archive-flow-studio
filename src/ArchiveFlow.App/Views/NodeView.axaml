<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             x:Class="ArchiveFlow.App.Views.NodeView"
             x:DataType="vm:NodeInstanceViewModel"
             Width="230"
             Height="118">

    <Grid>
        <Border Background="#2D2D30"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="2"
                CornerRadius="8"
                Padding="12"
                Margin="10,0"
                PointerPressed="Node_PointerPressed">
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Title}"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="1"
                            Background="{Binding BadgeBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            Margin="8,0,0,0">
                        <TextBlock Text="{Binding BadgeText}"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="{Binding NodeType}"
                               Foreground="#A0A0A0"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding ModeText}"
                               Foreground="#CCCCCC"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Status}"
                               Foreground="#8BC34A"
                               FontSize="11"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding InputCount, StringFormat='In: {0}'}"
                               Foreground="#999999"
                               FontSize="10"
                               Margin="0,0,6,0"/>
                </Grid>
            </Grid>
        </Border>

        <Ellipse Width="12"
                 Height="12"
                 Fill="{Binding AccentBrush}"
                 Stroke="White"
                 StrokeThickness="1"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="2,0,0,0"/>

        <Ellipse Width="12"
                 Height="12"
                 Fill="{Binding AccentBrush}"
                 Stroke="White"
                 StrokeThickness="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Margin="0,0,2,0"/>
    </Grid>
</UserControl>