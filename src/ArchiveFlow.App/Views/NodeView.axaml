<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:conv="using:ArchiveFlow.App.Converters"
             x:Class="ArchiveFlow.App.Views.NodeView"
             x:DataType="vm:NodeViewModel"
             Width="200" Height="130">

    <Grid>
        <Border Background="#2D2D30" 
                BorderBrush="{Binding IsSelected, Converter={x:Static conv:BoolToBrushConverter.Instance}}" 
                BorderThickness="2" 
                CornerRadius="8"
                Margin="10,0" 
                BoxShadow="0 4 6 rgba(0,0,0,0.3)" 
                PointerPressed="NodeBody_PointerPressed">
            <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="15,10">
                <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Bold" Foreground="White" FontSize="14"/>
                
                <TextBox Grid.Row="1" Text="{Binding ParameterValue}" 
                         PlaceholderText="Parameter..."
                         Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#555"
                         Margin="0,5" FontSize="11" Height="24"
                         PointerPressed="TextBox_PointerPressed"/>

                <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Margin="0,5">
                    <TextBlock Text="{Binding NodeType}" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                </Border>
                <TextBlock Grid.Row="3" Text="{Binding Status}" Foreground="#00FF00" FontSize="11" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Ellipse Width="16" Height="16" Fill="#007ACC" Stroke="White" StrokeThickness="2"
                 HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-8,0,0,0" PointerReleased="InputPort_PointerReleased"/>
        <Ellipse Width="16" Height="16" Fill="#007ACC" Stroke="White" StrokeThickness="2"
                 HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-8,0" PointerPressed="OutputPort_PointerPressed"/>
    </Grid>
</UserControl>
