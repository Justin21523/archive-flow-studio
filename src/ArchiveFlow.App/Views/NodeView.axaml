<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             x:Class="ArchiveFlow.App.Views.NodeView"
             x:DataType="vm:NodeViewModel"
             Width="200" Height="100">

    <Canvas Width="200" Height="100">
        <!-- Main Node Body -->
        <Border Width="180" Height="80" 
                Canvas.Left="10" Canvas.Top="10"
                Background="#2D2D30" 
                BorderBrush="#007ACC" 
                BorderThickness="2" 
                CornerRadius="8"
                BoxShadow="0 4 6 rgba(0,0,0,0.5)"
                PointerPressed="NodeBody_PointerPressed">
            <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="15,10">
                <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Bold" Foreground="White" FontSize="14"/>
                
                <!-- 參數輸入框 (只有當 ParameterValue 有意義時顯示，這裡我們讓它永遠顯示但透明背景) -->
                <TextBox Grid.Row="1" Text="{Binding ParameterValue}" 
                         PlaceholderText="Enter parameter..."
                         Background="#1E1E1E" Foreground="White" BorderThickness="0"
                         Margin="0,5" FontSize="12" Height="24"
                         PointerPressed="TextBox_PointerPressed"/> <!-- 阻止點擊 TextBox 時拖曳節點 -->

                <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Margin="0,5">
                    <TextBlock Text="{Binding NodeType}" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Row="3" Text="{Binding Status}" Foreground="#00FF00" FontSize="12" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Input Port (Left) -->
        <Ellipse Width="16" Height="16" Fill="#007ACC" Stroke="White" StrokeThickness="2"
                 Canvas.Left="2" Canvas.Top="42"
                 PointerReleased="InputPort_PointerReleased"
                 Cursor="Hand"/>

        <!-- Output Port (Right) -->
        <Ellipse Width="16" Height="16" Fill="#007ACC" Stroke="White" StrokeThickness="2"
                 Canvas.Left="182" Canvas.Top="42"
                 PointerPressed="OutputPort_PointerPressed"
                 Cursor="Hand"/>
    </Canvas>
</UserControl>
