<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:conv="using:ArchiveFlow.App.Converters"
             x:Class="ArchiveFlow.App.Views.NodeView"
             x:DataType="vm:NodeViewModel"
             Width="200" Height="100">

    <Border Background="#2D2D30" 
            BorderBrush="{Binding IsSelected, Converter={x:Static conv:BoolToBrushConverter.Instance}}" 
            BorderThickness="2" 
            CornerRadius="8"
            BoxShadow="0 4 6 rgba(0,0,0,0.3)"
            PointerPressed="Node_PointerPressed"
            PointerMoved="Node_PointerMoved"
            PointerReleased="Node_PointerReleased">
        <Grid RowDefinitions="Auto,*,Auto" Margin="10">
            <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Bold" Foreground="White" FontSize="14"/>
            <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4" Margin="0,5">
                <TextBlock Text="Data Flow" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Row="2" Text="{Binding Status}" Foreground="#00FF00" FontSize="12" HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</UserControl>