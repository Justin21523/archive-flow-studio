<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             x:Class="ArchiveFlow.App.Views.NodeView"
             x:DataType="vm:NodeViewModel"
             Width="220" Height="140">

    <Grid>
        <!-- Main Node Body -->
        <Border Background="#2D2D30" 
                BorderBrush="{Binding AccentColor}" 
                BorderThickness="2" 
                CornerRadius="8"
                Margin="10,0" 
                BoxShadow="0 4 6 rgba(0,0,0,0.3)" 
                PointerPressed="NodeBody_PointerPressed">
            <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="15,10">
                <!-- Header with Badge -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" 
                              Text="{Binding Title}" 
                              FontWeight="Bold" 
                              Foreground="White" 
                              FontSize="14" 
                              VerticalAlignment="Center"/>
                    <Border Grid.Column="1" 
                           Background="{Binding BadgeColor}" 
                           CornerRadius="4" 
                           Padding="6,2"
                           Margin="5,0,0,0">
                        <TextBlock Text="{Binding BadgeText}" 
                                  Foreground="White" 
                                  FontSize="10" 
                                  FontWeight="Bold"/>
                    </Border>
                </Grid>
                
                <!-- Parameters -->
                <ItemsControl Grid.Row="1" 
                             ItemsSource="{Binding Parameters}" 
                             Margin="0,5,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NodeParameterViewModel">
                            <StackPanel Margin="0,2">
                                <TextBlock Text="{Binding Label}" 
                                          Foreground="#888" 
                                          FontSize="10"/>
                                <TextBox Text="{Binding Value}" 
                                        Background="#1E1E1E" 
                                        Foreground="White" 
                                        BorderThickness="0" 
                                        FontSize="11" 
                                        Height="24" 
                                        Padding="5,2" 
                                        CornerRadius="4"
                                        PointerPressed="TextBox_PointerPressed"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Description -->
                <Border Grid.Row="2" 
                       Background="#1E1E1E" 
                       CornerRadius="4" 
                       Margin="0,5">
                    <TextBlock Text="{Binding NodeType}" 
                              Foreground="#666" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center" 
                              FontSize="10" 
                              TextWrapping="Wrap" 
                              Margin="5"/>
                </Border>
                
                <!-- Status -->
                <TextBlock Grid.Row="3" 
                          Text="{Binding Status}" 
                          Foreground="#00FF00" 
                          FontSize="11" 
                          HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Input Port (Left) -->
        <Ellipse Width="16" Height="16" 
                Fill="{Binding AccentColor}" 
                Stroke="White" 
                StrokeThickness="2"
                HorizontalAlignment="Left" 
                VerticalAlignment="Center" 
                Margin="-8,0,0,0" 
                PointerReleased="InputPort_PointerReleased"/>

        <!-- Output Port (Right) -->
        <Ellipse Width="16" Height="16" 
                Fill="{Binding AccentColor}" 
                Stroke="White" 
                StrokeThickness="2"
                HorizontalAlignment="Right" 
                VerticalAlignment="Center" 
                Margin="0,0,-8,0" 
                PointerPressed="OutputPort_PointerPressed"/>
    </Grid>
</UserControl>