<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             x:Class="ArchiveFlow.App.Views.NodeView"
             x:DataType="vm:NodeInstanceViewModel"
             Width="220">

    <Grid>
        <Ellipse Width="14"
                 Height="14"
                 Fill="#252526"
                 Stroke="#888888"
                 StrokeThickness="2"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Margin="-7,0,0,0"
                 IsVisible="{Binding InputCount}"/>

        <Border Background="#2D2D30"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="2"
                CornerRadius="6"
                PointerPressed="NodeBody_PointerPressed">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  Margin="10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Subcategory}"
                                   Foreground="#9E9E9E"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{Binding BadgeBrush}"
                            CornerRadius="3"
                            Padding="5,2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding BadgeText}"
                                   Foreground="White"
                                   FontSize="9"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding Description}"
                           Foreground="#BBBBBB"
                           FontSize="10"
                           TextWrapping="Wrap"
                           MaxHeight="38"
                           Margin="0,8,0,0"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding Status}"
                           Foreground="#80CBC4"
                           FontSize="10"
                           Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <Ellipse Width="16"
                 Height="16"
                 Fill="#007ACC"
                 Stroke="White"
                 StrokeThickness="2"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Margin="0,0,-8,0"
                 PointerPressed="OutputPort_PointerPressed"
                 IsVisible="{Binding OutputCount}"/>
    </Grid>
</UserControl>
