<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArchiveFlow.App.ViewModels"
        x:Class="ArchiveFlow.App.Views.MetadataEditorWindow"
        x:DataType="vm:MetadataEditorViewModel"
        Title="Metadata Editor"
        Width="1100"
        Height="780"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Background="#252526"
                Padding="22,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="Metadata Editor"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding FileName}"
                               Foreground="#CCCCCC"
                               FontSize="14"
                               Margin="0,6,0,0"/>

                    <TextBlock Text="{Binding FileId}"
                               Foreground="#4FC3F7"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Completeness"
                               Foreground="#AAAAAA"
                               HorizontalAlignment="Right"
                               FontSize="12"/>

                    <TextBlock Text="{Binding MetadataCompletenessText}"
                               Foreground="#8BC34A"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="280,*"
              Margin="18">
            <Border Grid.Column="0"
                    Background="#252526"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Basic File Info"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Archive ID"
                               Foreground="#888888"
                               FontSize="11"/>
                    <TextBlock Text="{Binding ArchiveId}"
                               Foreground="#4FC3F7"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="Extension"
                               Foreground="#888888"
                               FontSize="11"/>
                    <TextBlock Text="{Binding FileExtension}"
                               Foreground="White"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="Imported"
                               Foreground="#888888"
                               FontSize="11"/>
                    <TextBlock Text="{Binding ImportedAtText}"
                               Foreground="White"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="Path"
                               Foreground="#888888"
                               FontSize="11"/>
                    <TextBlock Text="{Binding FilePath}"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,4,0,20"/>

                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Add New Field"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Field Name"
                                       Foreground="#888888"
                                       FontSize="11"/>
                            <TextBox Text="{Binding NewFieldName, Mode=TwoWay}"
                                     PlaceholderText="e.g. reading_status"
                                     Background="#2D2D30"
                                     Foreground="White"
                                     BorderBrush="#444444"
                                     Padding="8,6"
                                     Margin="0,4,0,10"/>

                            <TextBlock Text="Display Name"
                                       Foreground="#888888"
                                       FontSize="11"/>
                            <TextBox Text="{Binding NewDisplayName, Mode=TwoWay}"
                                     PlaceholderText="Optional"
                                     Background="#2D2D30"
                                     Foreground="White"
                                     BorderBrush="#444444"
                                     Padding="8,6"
                                     Margin="0,4,0,10"/>

                            <TextBlock Text="Category"
                                       Foreground="#888888"
                                       FontSize="11"/>
                            <ComboBox ItemsSource="{Binding NewFieldCategoryOptions}"
                                      SelectedItem="{Binding NewFieldCategory, Mode=TwoWay}"
                                      Background="#2D2D30"
                                      Foreground="White"
                                      BorderBrush="#444444"
                                      Padding="8,6"
                                      Margin="0,4,0,10"/>

                            <TextBlock Text="Field Type"
                                       Foreground="#888888"
                                       FontSize="11"/>
                            <ComboBox ItemsSource="{Binding NewFieldTypeOptions}"
                                      SelectedItem="{Binding NewFieldType, Mode=TwoWay}"
                                      Background="#2D2D30"
                                      Foreground="White"
                                      BorderBrush="#444444"
                                      Padding="8,6"
                                      Margin="0,4,0,10"/>

                            <CheckBox IsChecked="{Binding NewIsRequired, Mode=TwoWay}"
                                      Content="Required"
                                      Foreground="White"
                                      Margin="0,0,0,10"/>

                            <TextBlock Text="Value"
                                       Foreground="#888888"
                                       FontSize="11"/>
                            <TextBox Text="{Binding NewValueText, Mode=TwoWay}"
                                     PlaceholderText="Enter metadata value"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="70"
                                     Background="#2D2D30"
                                     Foreground="White"
                                     BorderBrush="#444444"
                                     Padding="8,6"
                                     Margin="0,4,0,12"/>

                            <Button Content="Add Field"
                                    Command="{Binding AddFieldCommand}"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,8"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <TabControl Grid.Column="1"
                        Background="#1E1E1E">
                <TabItem Header="Basic">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding BasicFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataEditorFieldViewModel">
                                    <Border Background="#252526"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto">
                                            <Grid Grid.Row="0"
                                                  Grid.Column="0"
                                                  ColumnDefinitions="160,*,150,130">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DisplayName, Mode=TwoWay}"
                                                         Background="#1E1E1E"
                                                         Foreground="White"
                                                         BorderBrush="#444444"
                                                         Padding="8,6"/>

                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding CategoryOptions}"
                                                          SelectedItem="{Binding Category, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>

                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{Binding FieldTypeOptions}"
                                                          SelectedItem="{Binding FieldType, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>

                                                <CheckBox Grid.Column="3"
                                                          IsChecked="{Binding IsRequired, Mode=TwoWay}"
                                                          Content="Required"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"
                                                          Margin="8,0,0,0"/>
                                            </Grid>

                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Content="Delete"
                                                    Tag="{Binding}"
                                                    Click="RemoveFieldButton_Click"
                                                    Foreground="#FF6B6B"
                                                    Padding="10,6"
                                                    Margin="10,0,0,0"/>

                                            <TextBox Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Text="{Binding ValueText, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     Background="#1E1E1E"
                                                     Foreground="White"
                                                     BorderBrush="#444444"
                                                     Padding="10,8"
                                                     MinHeight="68"
                                                     Margin="0,12,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Descriptive Metadata">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding DescriptiveFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataEditorFieldViewModel">
                                    <Border Background="#252526"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto">
                                            <Grid Grid.Row="0"
                                                  Grid.Column="0"
                                                  ColumnDefinitions="160,*,150,130">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DisplayName, Mode=TwoWay}"
                                                         Background="#1E1E1E"
                                                         Foreground="White"
                                                         BorderBrush="#444444"
                                                         Padding="8,6"/>
                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding CategoryOptions}"
                                                          SelectedItem="{Binding Category, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>
                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{Binding FieldTypeOptions}"
                                                          SelectedItem="{Binding FieldType, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>
                                                <CheckBox Grid.Column="3"
                                                          IsChecked="{Binding IsRequired, Mode=TwoWay}"
                                                          Content="Required"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"
                                                          Margin="8,0,0,0"/>
                                            </Grid>

                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Content="Delete"
                                                    Tag="{Binding}"
                                                    Click="RemoveFieldButton_Click"
                                                    Foreground="#FF6B6B"
                                                    Padding="10,6"
                                                    Margin="10,0,0,0"/>

                                            <TextBox Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Text="{Binding ValueText, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     Background="#1E1E1E"
                                                     Foreground="White"
                                                     BorderBrush="#444444"
                                                     Padding="10,8"
                                                     MinHeight="90"
                                                     Margin="0,12,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Personal Knowledge">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding PersonalFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataEditorFieldViewModel">
                                    <Border Background="#252526"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto">
                                            <Grid Grid.Row="0"
                                                  Grid.Column="0"
                                                  ColumnDefinitions="160,*,150,130">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DisplayName, Mode=TwoWay}"
                                                         Background="#1E1E1E"
                                                         Foreground="White"
                                                         BorderBrush="#444444"
                                                         Padding="8,6"/>
                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding CategoryOptions}"
                                                          SelectedItem="{Binding Category, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>
                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{Binding FieldTypeOptions}"
                                                          SelectedItem="{Binding FieldType, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>
                                                <CheckBox Grid.Column="3"
                                                          IsChecked="{Binding IsRequired, Mode=TwoWay}"
                                                          Content="Required"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"
                                                          Margin="8,0,0,0"/>
                                            </Grid>

                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Content="Delete"
                                                    Tag="{Binding}"
                                                    Click="RemoveFieldButton_Click"
                                                    Foreground="#FF6B6B"
                                                    Padding="10,6"
                                                    Margin="10,0,0,0"/>

                                            <TextBox Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Text="{Binding ValueText, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     Background="#1E1E1E"
                                                     Foreground="White"
                                                     BorderBrush="#444444"
                                                     Padding="10,8"
                                                     MinHeight="68"
                                                     Margin="0,12,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Technical Metadata">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding TechnicalFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataEditorFieldViewModel">
                                    <Border Background="#252526"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="*,Auto">
                                            <Grid Grid.Row="0"
                                                  Grid.Column="0"
                                                  ColumnDefinitions="160,*,150,130">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DisplayName, Mode=TwoWay}"
                                                         Background="#1E1E1E"
                                                         Foreground="White"
                                                         BorderBrush="#444444"
                                                         Padding="8,6"/>
                                                <ComboBox Grid.Column="1"
                                                          ItemsSource="{Binding CategoryOptions}"
                                                          SelectedItem="{Binding Category, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>
                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{Binding FieldTypeOptions}"
                                                          SelectedItem="{Binding FieldType, Mode=TwoWay}"
                                                          Background="#1E1E1E"
                                                          Foreground="White"
                                                          BorderBrush="#444444"
                                                          Padding="8,6"
                                                          Margin="8,0,0,0"/>
                                                <CheckBox Grid.Column="3"
                                                          IsChecked="{Binding IsRequired, Mode=TwoWay}"
                                                          Content="Required"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"
                                                          Margin="8,0,0,0"/>
                                            </Grid>

                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Content="Delete"
                                                    Tag="{Binding}"
                                                    Click="RemoveFieldButton_Click"
                                                    Foreground="#FF6B6B"
                                                    Padding="10,6"
                                                    Margin="10,0,0,0"/>

                                            <TextBox Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Text="{Binding ValueText, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     Background="#1E1E1E"
                                                     Foreground="White"
                                                     BorderBrush="#444444"
                                                     Padding="10,8"
                                                     MinHeight="68"
                                                     Margin="0,12,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2"
                Background="#252526"
                Padding="18">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#BBBBBB"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>

                <Button Grid.Column="1"
                        Content="Reload"
                        Command="{Binding ReloadCommand}"
                        Padding="16,8"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="18,8"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Content="Save and Close"
                        Command="{Binding SaveAndCloseCommand}"
                        Padding="18,8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
