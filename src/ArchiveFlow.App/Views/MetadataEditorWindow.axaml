<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArchiveFlow.App.ViewModels"
        xmlns:domain="using:ArchiveFlow.Domain.Entities"
        x:Class="ArchiveFlow.App.Views.MetadataEditorWindow"
        x:DataType="vm:MetadataEditorViewModel"
        Title="Metadata Editor"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="20,15" CornerRadius="8,8,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="Metadata Editor" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding FileName}" Foreground="#888" FontSize="13" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding FileId}" Foreground="#007ACC" FontSize="11" FontFamily="Consolas" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="" FontSize="16" Width="32" Height="32"
                       Command="{Binding CloseCommand}"
                       Background="Transparent" Foreground="#888"
                       CornerRadius="4" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Main Content: TabControl for Categories -->
        <TabControl Grid.Row="1" Background="#1E1E1E" Margin="20,15,20,15">
            
            <!-- Basic Metadata Tab -->
            <TabItem Header="Basic">
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <TextBlock Text="Core Information" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                        
                        <ItemsControl ItemsSource="{Binding BasicFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataFieldViewModel">
                                    <Border Background="#2D2D30" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="150,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding FieldName}" 
                                                      Foreground="#007ACC" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding ValueText}" 
                                                    Background="#1E1E1E" Foreground="White"
                                                    CornerRadius="4" Padding="10,8"
                                                    Margin="10,0"/>
                                            <Button Grid.Column="2" Content="Remove" 
                                                   Command="{ReflectionBinding $parent[Window].DataContext.RemoveFieldCommand}"
                                                   CommandParameter="{Binding}"
                                                   Foreground="#FF6B6B" Padding="8,4"
                                                   HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Descriptive Metadata Tab (Dublin Core) -->
            <TabItem Header="Descriptive">
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <TextBlock Text="Dublin Core Elements" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                        
                        <ItemsControl ItemsSource="{Binding DescriptiveFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataFieldViewModel">
                                    <Border Background="#2D2D30" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="150,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding FieldName}" 
                                                      Foreground="#007ACC" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding ValueText}" 
                                                    Background="#1E1E1E" Foreground="White"
                                                    CornerRadius="4" Padding="10,8"
                                                    Margin="10,0"
                                                    AcceptsReturn="True"
                                                    TextWrapping="Wrap"
                                                    MinHeight="60"/>
                                            <Button Grid.Column="2" Content="Remove" 
                                                   Command="{ReflectionBinding $parent[Window].DataContext.RemoveFieldCommand}"
                                                   CommandParameter="{Binding}"
                                                   Foreground="#FF6B6B" Padding="8,4"
                                                   HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Personal Knowledge Tab -->
            <TabItem Header="Personal">
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <TextBlock Text="Personal Knowledge Fields" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                        
                        <ItemsControl ItemsSource="{Binding PersonalFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataFieldViewModel">
                                    <Border Background="#2D2D30" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="150,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding FieldName}" 
                                                      Foreground="#007ACC" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding ValueText}" 
                                                    Background="#1E1E1E" Foreground="White"
                                                    CornerRadius="4" Padding="10,8"
                                                    Margin="10,0"/>
                                            <Button Grid.Column="2" Content="Remove" 
                                                   Command="{ReflectionBinding $parent[Window].DataContext.RemoveFieldCommand}"
                                                   CommandParameter="{Binding}"
                                                   Foreground="#FF6B6B" Padding="8,4"
                                                   HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Technical Metadata Tab -->
            <TabItem Header="Technical">
                <ScrollViewer>
                    <StackPanel Margin="15">
                        <TextBlock Text="Technical Metadata" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                        
                        <ItemsControl ItemsSource="{Binding TechnicalFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MetadataFieldViewModel">
                                    <Border Background="#2D2D30" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="150,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding FieldName}" 
                                                      Foreground="#007ACC" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding ValueText}" 
                                                    Background="#1E1E1E" Foreground="White"
                                                    CornerRadius="4" Padding="10,8"
                                                    Margin="10,0"
                                                    IsReadOnly="True"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Add New Field Tab -->
            <TabItem Header="+ Add Field">
                <StackPanel Margin="15">
                    <TextBlock Text="Add New Metadata Field" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                    
                    <Border Background="#2D2D30" CornerRadius="6" Padding="20">
                        <StackPanel Spacing="15">
                            <StackPanel>
                                <TextBlock Text="Field Name" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewFieldName}" Background="#1E1E1E" Foreground="White"
                                        CornerRadius="4" Padding="10,8" PlaceholderText="e.g., Author, Subject, Tag"/>
                            </StackPanel>
                            
                            <StackPanel>
                                <TextBlock Text="Category" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox SelectedItem="{Binding NewFieldCategory}" Background="#1E1E1E" Foreground="White"
                                         CornerRadius="4" Padding="10,8">
                                    <ComboBoxItem Content="Basic"/>
                                    <ComboBoxItem Content="Descriptive"/>
                                    <ComboBoxItem Content="Personal"/>
                                    <ComboBoxItem Content="Technical"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel>
                                <TextBlock Text="Value" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding NewFieldValue}" Background="#1E1E1E" Foreground="White"
                                        CornerRadius="4" Padding="10,8" PlaceholderText="Enter value..."
                                        AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                            </StackPanel>
                            
                            <Button Content="Add Field" Command="{Binding AddFieldCommand}"
                                   Classes="accent" HorizontalAlignment="Stretch" Padding="12,10"
                                   FontSize="14"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Footer: Save/Cancel Buttons -->
        <Border Grid.Row="2" Background="#252526" Padding="20,15" CornerRadius="0,0,8,8">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#888" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Cancel" Command="{Binding CloseCommand}"
                       Padding="15,8" Margin="0,0,10,0" Background="#2D2D30" Foreground="White"
                       CornerRadius="4"/>
                <Button Grid.Column="2" Content="Save Changes" Command="{Binding SaveCommand}"
                       Classes="accent" Padding="20,8" CornerRadius="4"/>
            </Grid>
        </Border>
    </Grid>
</Window>
