<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArchiveFlow.App.ViewModels"
        xmlns:views="using:ArchiveFlow.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="ArchiveFlow.App.Views.MainWindow"
        x:DataType="vm:NodeCanvasViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ArchiveFlow Studio"
        Width="1200" Height="800">

    <DockPanel>
        <!-- Top Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New Workflow" Command="{Binding SaveWorkflowCommand}"/> <!-- Reusing for demo -->
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Delete Selected Node" Command="{Binding DeleteSelectedNodeCommand}" InputGesture="Delete"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Dashboard" Click="GoToDashboard_Click"/>
                <MenuItem Header="Workspace" Click="GoToWorkspace_Click"/>
            </MenuItem>
            <MenuItem Header="Workflow">
                <MenuItem Header="Execute" Command="{Binding ExecuteWorkflowCommand}" InputGesture="F5"/>
                <Separator/>
                <MenuItem Header="Save" Command="{Binding SaveWorkflowCommand}"/>
                <MenuItem Header="Load" Command="{Binding LoadWorkflowCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area with Tabs -->
        <TabControl x:Name="MainTabControl" Background="#1E1E1E">
            <TabItem Header="Dashboard" IsSelected="True">
                <views:DashboardView/>
            </TabItem>
            <TabItem Header="Workspace">
                <views:NodeCanvasView/>
            </TabItem>
            <TabItem Header="Graph Explorer" x:Name="GraphExplorerTab">
                <views:GraphExplorerView/>
            </TabItem>
            <!-- 新增 Database Manager Tab -->
            <TabItem Header="Database Manager">
                <views:DatabaseManagerView DataContext="{DynamicResource DatabaseManagerViewModel}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>