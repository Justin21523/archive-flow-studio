<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArchiveFlow.App.ViewModels"
        xmlns:views="using:ArchiveFlow.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ArchiveFlow.App.Views.MainWindow"
        x:DataType="vm:NodeCanvasViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ArchiveFlow Studio - Node Canvas"
        Width="1000" Height="700">

    <Design.DataContext>
        <vm:NodeCanvasViewModel/>
    </Design.DataContext>

    <!-- Directly embed the NodeCanvasView -->
    <views:NodeCanvasView />

</Window>