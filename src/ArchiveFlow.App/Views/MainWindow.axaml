<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArchiveFlow.App.ViewModels"
        x:Class="ArchiveFlow.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="650"
        Background="#1E1E1E">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#252526"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="ArchiveFlow Studio"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Node-based Personal Digital Archive &amp; Metadata Workflow System"
                               Foreground="#999999"
                               FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#8BC34A"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TabControl Background="#1E1E1E">
            <TabItem Header="Dashboard">
                <Grid Margin="24">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Text="Archive Health Dashboard"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="Bold"/>

                        <Border Grid.Row="1"
                                Margin="0,20,0,20"
                                Background="#2D2D30"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Current Database"
                                           Foreground="#BBBBBB"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding DatabasePath}"
                                           Foreground="#4FC3F7"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Background="#252526"
                                CornerRadius="8"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Next step"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Phase 0.2 will restore the Node Workspace using NodeDefinition as the single source of truth."
                                           Foreground="#CCCCCC"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Workspace">
                <Grid Margin="24">
                    <Border Background="#252526"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Node Workspace"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock Text="The stable Node Canvas will be rebuilt in Phase 0.2."
                                       Foreground="#BBBBBB"
                                       FontSize="14"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Metadata">
                <Grid Margin="24">
                    <Border Background="#252526"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Metadata System"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Standalone Metadata Editor will be implemented after the Node Canvas baseline is stable."
                                       Foreground="#BBBBBB"
                                       FontSize="14"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>