<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ArchiveFlow.App.Views.DashboardView">
    
    <ScrollViewer Background="#1E1E1E">
        <StackPanel Margin="40">
            <TextBlock Text="ArchiveFlow Studio" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <TextBlock Text="Node-based Personal Digital Archive &amp; Metadata Workflow System" FontSize="16" Foreground="Gray" Margin="0,0,0,40"/>

            <TextBlock Text="Quick Access" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20"/>
            
            <WrapPanel>
                <!-- Workspace Card -->
                <Border Width="250" Height="150" Background="#2D2D30" CornerRadius="8" Margin="0,0,20,20" 
                        BoxShadow="0 4 6 rgba(0,0,0,0.3)" Cursor="Hand"
                        Tag="Workspace">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" Fill="#007ACC" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Node Workspace" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Open the node canvas to build workflows" FontSize="12" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Placeholder Cards -->
                <Border Width="250" Height="150" Background="#2D2D30" CornerRadius="8" Margin="0,0,20,20" Opacity="0.5">
                    <Grid Margin="20">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Metadata Catalog" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Manage tags, subjects, and fields" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Generate Mock Data Button -->
                <Border Width="250" Height="150" Background="#2D2D30" CornerRadius="8" Margin="0,0,20,20" 
                        BoxShadow="0 4 6 rgba(0,0,0,0.3)" Cursor="Hand"
                        Tag="GenerateData" x:Name="GenerateDataCard">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Fill="#FFA500" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Generate Massive Mock Data" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Create 200+ realistic files for testing" FontSize="12" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
