<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:domain="using:ArchiveFlow.Domain.Entities"
             xmlns:app="using:ArchiveFlow.Application.Interfaces"
             xmlns:defs="using:ArchiveFlow.Application.Nodes.Definitions"
             xmlns:converters="using:ArchiveFlow.App.Converters"
             x:Class="ArchiveFlow.App.Views.NodeCanvasView"
             x:DataType="vm:NodeCanvasViewModel"
             Focusable="True"
             KeyDown="UserControl_KeyDown">

    <DockPanel>
        <!-- Bottom: Batch Job Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D30" Padding="15,10" CornerRadius="4" Margin="10,0,10,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Batch Job:" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentBatchJob.JobName}" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding CurrentBatchJob.StatusMessage}" Foreground="Gray" FontSize="12"/>
                </StackPanel>

                <ProgressBar Grid.Column="2" Width="150" Height="10" 
                             IsIndeterminate="{Binding CurrentBatchJob.IsActive}" 
                             Margin="15,0" VerticalAlignment="Center"/>

                <Button Grid.Column="3" Content="Run Mock Job" 
                        Command="{Binding RunMockBatchJobCommand}" 
                        Classes="accent" Padding="10,5" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content Grid -->
        <Grid ColumnDefinitions="250,*,350" DockPanel.Dock="Top">
            
        <!-- Left: Dynamic Hierarchical Node Library -->
        <Border Grid.Column="0" Background="#252526" Margin="0,0,5,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Text="Node Library" FontWeight="Bold" Foreground="White" Margin="15,15,15,10"/>
                
                <!-- TreeView bound to NodeLibraryGroups -->
                <TreeView Grid.Row="1" ItemsSource="{Binding NodeLibraryGroups}" Margin="10,0,10,10">
                    <TreeView.DataTemplates>
                        <TreeDataTemplate DataType="vm:NodeCategoryGroup" x:DataType="vm:NodeCategoryGroup" ItemsSource="{Binding Definitions}">
                            <TextBlock Text="{Binding Name}" Foreground="#888" FontWeight="Bold" FontSize="12" Margin="5,10,5,5"/>
                        </TreeDataTemplate>

                        <DataTemplate DataType="defs:NodeDefinition" x:DataType="defs:NodeDefinition">
                            <Border Padding="8,6"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    PointerPressed="NodeLibraryItem_PointerPressed"
                                    Tag="{Binding .}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Accent Color Indicator -->
                                    <Border Width="4" Height="16" CornerRadius="2" Background="{Binding AccentColor}" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="13"/>
                                        <TextBlock Text="{Binding Description}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>

                <Border Grid.Row="2"
                        BorderBrush="#3E3E42"
                        BorderThickness="0,1,0,0"
                        Padding="10"
                        Background="#252526">
                    <Button Content="Execute Workflow"
                            Command="{Binding ExecuteWorkflowCommand}"
                            Classes="accent"
                            HorizontalAlignment="Stretch"
                            Padding="12,8"/>
                </Border>
            </Grid>
        </Border>

            <!-- Center: Canvas with Performance Optimization -->
            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="4" ClipToBounds="True" Margin="5,0">
                <!-- Optimized ScrollViewer with Virtualization -->
                <ScrollViewer x:Name="CanvasViewport"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              SizeChanged="CanvasViewport_SizeChanged"
                              ScrollChanged="CanvasViewport_ScrollChanged">
                    
                    <Canvas x:Name="MainCanvas" 
                            Width="5000" Height="5000" 
                            Background="Transparent"
                            PointerMoved="Canvas_PointerMoved" 
                            PointerReleased="Canvas_PointerReleased"
                            PointerPressed="Canvas_PointerPressed">
                        
                        <!-- Context Menu -->
                        <Canvas.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Node">
                                    <MenuItem Header="Sources">
                                        <MenuItem Header="All Files" Command="{Binding AddAllFilesCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Filters">
                                        <MenuItem Header="Filter .txt" Command="{Binding AddFilterTxtCommand}"/>
                                        <MenuItem Header="Filter .md" Command="{Binding AddFilterMdCommand}"/>
                                        <MenuItem Header="Dynamic Rule" Command="{Binding AddDynamicRuleCommand}"/>
                                        <MenuItem Header="Full Text Search" Command="{Binding AddFullTextSearchCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Actions">
                                        <MenuItem Header="Add Tag: AI" Command="{Binding AddTagAICommand}"/>
                                        <MenuItem Header="Auto-Tag Files" Command="{Binding AddAutoTagCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="DAG Logic">
                                        <MenuItem Header="Condition Branch" Command="{Binding AddConditionBranchCommand}"/>
                                        <MenuItem Header="Merge Branches" Command="{Binding AddMergeBranchesCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Relationships">
                                        <MenuItem Header="Link to Target" Command="{Binding AddCreateRelationshipCommand}"/>
                                        <MenuItem Header="Find Related" Command="{Binding AddFindRelatedCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Outputs">
                                        <MenuItem Header="Result Table" Command="{Binding AddResultTableCommand}"/>
                                        <MenuItem Header="Export CSV" Command="{Binding AddExportCsvCommand}"/>
                                        <MenuItem Header="Export JSON" Command="{Binding AddExportJsonCommand}"/>
                                        <MenuItem Header="Export Dublin Core XML" Command="{Binding AddExportDublinCoreCommand}"/>
                                    </MenuItem>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Delete Selected" Command="{Binding DeleteSelectedNodeCommand}" InputGesture="Delete"/>
                                <MenuItem Header="Clear Canvas" Command="{Binding ClearCanvasCommand}"/>
                            </ContextMenu>
                        </Canvas.ContextMenu>

                        <!-- Edge Layer (synchronized by code-behind for stable canvas geometry) -->
                        <Canvas x:Name="EdgeLayer" Width="5000" Height="5000"/>
                        
                        <!-- Temporary Connection Line -->
                        <Path Data="{Binding TempEdgePath}" 
                              Stroke="#FFA500" 
                              StrokeThickness="2.5" 
                              StrokeDashArray="5,3" 
                              Fill="Transparent"
                              Opacity="0.9"/>

                        <!-- Node Layer (Dynamically populated by code-behind) -->
                        <Canvas x:Name="NodeLayer" Width="5000" Height="5000"/>
                        
                    </Canvas>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: Node Settings + Inspector -->
            <Border Grid.Column="2" Background="#252526" Margin="5,0,0,0">
                <ScrollViewer>
                    <StackPanel Margin="15">
                        
                        <!-- Node Settings Panel -->
                        <Border IsVisible="{Binding SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}" 
                                Background="#1E1E1E" CornerRadius="6" Margin="0,0,0,15" 
                                BoxShadow="0 2 4 rgba(0,0,0,0.3)">
                            <StackPanel Margin="15">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                          Fill="#007ACC" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Node Settings" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                </StackPanel>
                                
                                <TextBlock Text="{Binding SelectedNode.Title}" 
                                           Foreground="#007ACC" 
                                           Margin="0,0,0,15"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                
                                <!-- Parameters List -->
                                <ItemsControl ItemsSource="{Binding SelectedNode.Parameters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NodeParameterViewModel">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Label}" 
                                                           Foreground="#888" 
                                                           FontSize="11"
                                                           Margin="0,0,0,5"/>
                                                
                                                <!-- Text Parameter -->
                                                <TextBox Text="{Binding Value}" 
                                                         IsVisible="{Binding Type, Converter={x:Static converters:IsEqualConverter.Instance}, ConverterParameter=Text}" 
                                                         Margin="0,2" 
                                                         Background="#2D2D30" 
                                                         Foreground="White"
                                                         CornerRadius="4"
                                                         Padding="8,6"/>
                                                
                                                <!-- Number Parameter -->
                                                <NumericUpDown Value="{Binding Value}" 
                                                               IsVisible="{Binding Type, Converter={x:Static converters:IsEqualConverter.Instance}, ConverterParameter=Number}" 
                                                               Margin="0,2"
                                                               Background="#2D2D30"
                                                               Foreground="White"
                                                               CornerRadius="4"/>
                                                
                                                <!-- Dropdown Parameter -->
                                                <ComboBox ItemsSource="{Binding Options}" 
                                                          SelectedItem="{Binding Value}" 
                                                          IsVisible="{Binding Type, Converter={x:Static converters:IsEqualConverter.Instance}, ConverterParameter=Dropdown}" 
                                                          Margin="0,2"
                                                          Background="#2D2D30"
                                                          Foreground="White"
                                                          CornerRadius="4"
                                                          Padding="8,6"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Node Actions -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                                    <Button Content="Duplicate" 
                                            Command="{Binding $parent[UserControl].DataContext.DuplicateNodeCommand}"
                                            CommandParameter="{Binding SelectedNode}"
                                            Classes="accent"
                                            Padding="10,5"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"/>
                                    <Button Content="Delete" 
                                            Command="{Binding $parent[UserControl].DataContext.DeleteSelectedNodeCommand}"
                                            Padding="10,5"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Foreground="#FF6B6B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- File Inspector Panel -->
                        <Border Background="#1E1E1E" CornerRadius="6" Margin="0,0,0,15">
                            <ScrollViewer>
                                <StackPanel Margin="15">
                                    <TextBlock Text="File Inspector" 
                                            FontWeight="Bold" 
                                            Foreground="White" 
                                            FontSize="14"
                                            Margin="0,0,0,10"/>
                                    
                                    <!-- File ID Display -->
                                    <Border IsVisible="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Background="#2D2D30"
                                        CornerRadius="4"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" 
                                                    Text="ID: " 
                                                    Foreground="#888" 
                                                    FontSize="11"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                            <TextBox Grid.Column="1" 
                                                    Text="{Binding SelectedFile.Id}" 
                                                    IsReadOnly="True"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="#007ACC"
                                                    FontFamily="Consolas, monospace"
                                                    FontSize="11"
                                                    VerticalAlignment="Center"
                                                    TextWrapping="Wrap"/>
                                            <Button Grid.Column="2" 
                                                Content="Copy"
                                                Command="{Binding CopyFileIdCommand}"
                                                Classes="accent"
                                                Padding="8,4"
                                                FontSize="10"
                                                VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Preview Area -->
                                    <Border Margin="0,0,0,10" 
                                        CornerRadius="4" 
                                        Background="#121212" 
                                        MaxHeight="200"
                                        MinHeight="100"
                                        IsVisible="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Grid>
                                            <Image Source="{Binding SelectedFileThumbnail}" 
                                                Stretch="Uniform" 
                                                Margin="10"
                                                IsVisible="{Binding SelectedFileThumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            <ScrollViewer IsVisible="{Binding SelectedFilePreviewText, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <TextBlock Text="{Binding SelectedFilePreviewText}" 
                                                        Foreground="#CCC" 
                                                        FontSize="12" 
                                                        FontFamily="Consolas, monospace"
                                                        TextWrapping="Wrap" 
                                                        Margin="10"/>
                                            </ScrollViewer>
                                            <TextBlock Text="No preview available" 
                                                    Foreground="#555" 
                                                    HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding SelectedFile, Converter={x:Static converters:NullToBoolConverter.Instance}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Metadata List -->
                                    <TextBlock Text="Metadata" 
                                            FontWeight="SemiBold" 
                                            Foreground="#888" 
                                            FontSize="12"
                                            Margin="0,0,0,8"/>
                                    <ListBox ItemsSource="{Binding SelectedFileMetadata}" 
                                            Margin="0,0,0,10"
                                            MaxHeight="200"
                                            Background="Transparent"
                                            BorderThickness="0">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2D2D30" 
                                                    CornerRadius="4" 
                                                    Margin="0,0,0,5"
                                                    Padding="10,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FieldName}" 
                                                                FontWeight="Bold" 
                                                                Foreground="#007ACC" 
                                                                FontSize="11"/>
                                                        <TextBlock Text="{Binding ValueText}" 
                                                                Foreground="White" 
                                                                FontSize="13"
                                                                TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Relationships Section (新增) -->
                                    <TextBlock Text="Relationships" 
                                            FontWeight="SemiBold" 
                                            Foreground="#888" 
                                            FontSize="12"
                                            Margin="0,0,0,8"
                                            IsVisible="{Binding SelectedFileRelationships.Count, Converter={x:Static converters:IsGreaterThanZeroConverter.Instance}}"/>
                                    <ListBox ItemsSource="{Binding SelectedFileRelationships}" 
                                            Margin="0,0,0,10"
                                            MaxHeight="150"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            IsVisible="{Binding SelectedFileRelationships.Count, Converter={x:Static converters:IsGreaterThanZeroConverter.Instance}}">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2D2D30" 
                                                    CornerRadius="4" 
                                                    Margin="0,0,0,5"
                                                    Padding="10,8">
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <Path Grid.Column="0" 
                                                            Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                                            Fill="#FF9800" 
                                                            Width="16" Height="16" 
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding RelationshipType}" 
                                                                    FontWeight="Bold" 
                                                                    Foreground="#FF9800" 
                                                                    FontSize="11"/>
                                                            <TextBlock Text="{Binding TargetFileName}" 
                                                                    Foreground="White" 
                                                                    FontSize="12"
                                                                    TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" 
                                                                Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" 
                                                                Foreground="#888"
                                                                FontSize="10"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Results Panel -->
                        <Border Background="#1E1E1E" CornerRadius="6">
                            <Grid RowDefinitions="Auto,*" Margin="15">
                                <TextBlock Grid.Row="0" 
                                           Text="Results" 
                                           FontWeight="Bold" 
                                           Foreground="White" 
                                           FontSize="14"
                                           Margin="0,0,0,10"/>
                                
                                <!-- Virtualized Results List -->
                                <ListBox Grid.Row="1" 
                                         ItemsSource="{Binding ResultFiles}" 
                                         Margin="0,0,0,10"
                                         MaxHeight="250"
                                         SelectionChanged="ResultList_SelectionChanged"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="domain:FileRecord">
                                            <Border Background="#2D2D30" 
                                                    CornerRadius="4" 
                                                    Margin="0,0,0,5"
                                                    Padding="10,8">
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <!-- File Icon -->
                                                    <Path Grid.Column="0" 
                                                          Data="{Binding FileExtension, Converter={x:Static converters:ExtensionToIconConverter.Instance}}" 
                                                          Fill="#007ACC" 
                                                          Width="20" Height="20" 
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,10,0"/>
                                                    
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileName}" 
                                                                   Foreground="White"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   FontSize="13"/>
                                                        <TextBlock Text="{Binding Id}" Foreground="#888" FontSize="10" FontFamily="Consolas"/>
                                                        <TextBlock Text="{Binding FileSize, Converter={x:Static converters:FileSizeConverter.Instance}}" 
                                                                   Foreground="#888"
                                                                   FontSize="11"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding Status}" 
                                                               Foreground="#00FF00"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
