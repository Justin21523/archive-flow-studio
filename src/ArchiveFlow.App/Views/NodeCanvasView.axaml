<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:domain="using:ArchiveFlow.Domain.Entities"
             x:Class="ArchiveFlow.App.Views.NodeCanvasView"
             x:DataType="vm:NodeCanvasViewModel"
             Focusable="True"
             KeyDown="UserControl_KeyDown">

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#2D2D30" Padding="15,10" CornerRadius="4" Margin="10,0,10,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Batch Job:" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentBatchJob.JobName}" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding CurrentBatchJob.StatusMessage}" Foreground="Gray" FontSize="12"/>
                </StackPanel>

                <ProgressBar Grid.Column="2" Width="150" Height="10"
                             IsIndeterminate="{Binding CurrentBatchJob.IsActive}"
                             Margin="15,0" VerticalAlignment="Center"/>

                <Button Grid.Column="3" Content="Run Mock Job"
                        Command="{Binding RunMockBatchJobCommand}"
                        Classes="accent" Padding="10,5" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="220,*,300" DockPanel.Dock="Top">
            <Border Grid.Column="0" Background="#252526" Margin="0,0,5,0">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Node Library" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

                        <Expander Header="Sources" IsExpanded="True" Margin="0,2">
                            <StackPanel Margin="10,5">
                                <Button Content="All Files" Command="{Binding AddAllFilesCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Filters &amp; Rules" IsExpanded="True" Margin="0,2">
                            <StackPanel Margin="10,5">
                                <Button Content="Filter .txt" Command="{Binding AddFilterTxtCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Filter .md" Command="{Binding AddFilterMdCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Dynamic Rule" Command="{Binding AddDynamicRuleCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Actions (Metadata)" IsExpanded="True" Margin="0,2">
                            <StackPanel Margin="10,5">
                                <Button Content="Add Tag: AI" Command="{Binding AddTagAICommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Set Subject: CS" Command="{Binding AddSubjectCSCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Auto-Tag Files" Command="{Binding AddAutoTagCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Search &amp; Export" IsExpanded="True" Margin="0,2">
                            <StackPanel Margin="10,5">
                                <Button Content="Full Text Search" Command="{Binding AddFullTextSearchCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Export CSV" Command="{Binding AddExportCsvCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Export JSON" Command="{Binding AddExportJsonCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="DAG Logic" IsExpanded="True" Margin="0,2">
                            <StackPanel Margin="10,5">
                                <Button Content="Condition Branch" Command="{Binding AddConditionBranchCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                                <Button Content="Merge Branches" Command="{Binding AddMergeBranchesCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Outputs" IsExpanded="True" Margin="0,2">
                            <StackPanel Margin="10,5">
                                <Button Content="Result Table" Command="{Binding AddResultTableCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Expander>

                        <Border Height="1" Background="Gray" Margin="0,15"/>

                        <Button Content="Execute Workflow (F5)" Command="{Binding ExecuteWorkflowCommand}" Classes="accent" Margin="0,5" HorizontalAlignment="Stretch"/>
                        <Button Content="Save Workflow" Command="{Binding SaveWorkflowCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                        <Button Content="Load Workflow" Command="{Binding LoadWorkflowCommand}" Margin="0,2" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="4" ClipToBounds="True">
                <ScrollViewer x:Name="CanvasViewport"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              SizeChanged="CanvasViewport_SizeChanged"
                              ScrollChanged="CanvasViewport_ScrollChanged">
                    <Canvas x:Name="MainCanvas" Width="3000" Height="2000" Background="Transparent"
                            PointerMoved="Canvas_PointerMoved" PointerReleased="Canvas_PointerReleased">
                        <Canvas.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Node">
                                    <MenuItem Header="Sources">
                                        <MenuItem Header="All Files" Command="{Binding AddAllFilesCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Filters">
                                        <MenuItem Header="Filter .txt" Command="{Binding AddFilterTxtCommand}"/>
                                        <MenuItem Header="Filter .md" Command="{Binding AddFilterMdCommand}"/>
                                        <MenuItem Header="Dynamic Rule" Command="{Binding AddDynamicRuleCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Actions">
                                        <MenuItem Header="Add Tag: AI" Command="{Binding AddTagAICommand}"/>
                                        <MenuItem Header="Set Subject: CS" Command="{Binding AddSubjectCSCommand}"/>
                                        <MenuItem Header="Auto-Tag Files" Command="{Binding AddAutoTagCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="DAG Logic">
                                        <MenuItem Header="Condition Branch" Command="{Binding AddConditionBranchCommand}"/>
                                        <MenuItem Header="Merge Branches" Command="{Binding AddMergeBranchesCommand}"/>
                                    </MenuItem>
                                    <MenuItem Header="Outputs">
                                        <MenuItem Header="Result Table" Command="{Binding AddResultTableCommand}"/>
                                    </MenuItem>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Delete Selected" Command="{Binding DeleteSelectedNodeCommand}" InputGesture="Delete"/>
                            </ContextMenu>
                        </Canvas.ContextMenu>

                        <Canvas x:Name="EdgeLayer" Width="3000" Height="2000" Background="Transparent"/>
                        <Path Data="{Binding TempEdgePath}" Stroke="#FFA500" StrokeThickness="3" StrokeDashArray="4,4" Fill="Transparent"/>
                        <Canvas x:Name="NodeLayer" Width="3000" Height="2000" Background="Transparent"/>
                    </Canvas>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#252526" Margin="5,0,0,0">
                <Grid RowDefinitions="*,Auto,200">
                    <Border Grid.Row="0" Margin="10,10,10,5" CornerRadius="4" Background="#1E1E1E">
                        <Grid RowDefinitions="Auto,Auto,*,Auto">
                            <TextBlock Grid.Row="0" Text="Inspector" FontWeight="Bold" Foreground="White" Margin="10"/>
                            <TextBlock Grid.Row="0" Text="{Binding SelectedFile.FileName}" HorizontalAlignment="Right" Margin="10" Foreground="Gray"/>

                            <Border Grid.Row="1" Margin="10,5,10,5" CornerRadius="4" Background="#121212" MaxHeight="200"
                                    IsVisible="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Grid>
                                    <Image Source="{Binding SelectedFileThumbnail}" Stretch="Uniform" Margin="10"
                                           IsVisible="{Binding SelectedFileThumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    <ScrollViewer IsVisible="{Binding SelectedFilePreviewText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding SelectedFilePreviewText}" Foreground="White" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" Margin="10"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="2" ItemsSource="{Binding SelectedFileMetadata}" Margin="10,0,10,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="domain:MetadataValue">
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding FieldName}" FontWeight="Bold" Foreground="#007ACC" FontSize="12"/>
                                            <TextBlock Text="{Binding ValueText}" Foreground="White" FontSize="14"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Height="1" Background="Gray" Margin="10,0"/>

                    <Border Grid.Row="2" Margin="10,5,10,10" CornerRadius="4" Background="#1E1E1E">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Text="Results" FontWeight="Bold" Foreground="White" Margin="10"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding ResultFiles}" Margin="10,0,10,10"
                                     SelectionChanged="ResultList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="domain:FileRecord">
                                        <TextBlock Text="{Binding FileName}" Foreground="White"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
