<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:views="using:ArchiveFlow.App.Views"
             x:Class="ArchiveFlow.App.Views.NodeCanvasView"
             x:DataType="vm:NodeCanvasViewModel">

    <Grid ColumnDefinitions="200,*,300">
        
        <!-- 左側：Node Library -->
        <Border Grid.Column="0" Background="#252526" Margin="0,0,5,0">
            <StackPanel Margin="10">
                <TextBlock Text="Node Library" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                
                <TextBlock Text="Sources" Foreground="Gray" Margin="0,5"/>
                <Button Content="All Files" Command="{Binding AddAllFilesCommand}" Margin="0,2"/>
                
                <TextBlock Text="Filters" Foreground="Gray" Margin="0,10,0,5"/>
                <Button Content="Filter .txt" Command="{Binding AddFilterTxtCommand}" Margin="0,2"/>
                <Button Content="Filter .md" Command="{Binding AddFilterMdCommand}" Margin="0,2"/>
                
                <TextBlock Text="Actions" Foreground="Gray" Margin="0,10,0,5"/>
                <Button Content="Add Tag: AI" Command="{Binding AddTagAICommand}" Margin="0,2"/>
                <Button Content="Set Subject: CS" Command="{Binding AddSubjectCSCommand}" Margin="0,2"/>
                
                <TextBlock Text="Search" Foreground="Gray" Margin="0,10,0,5"/>
                <Button Content="Full Text Search" Command="{Binding AddFullTextSearchCommand}" Margin="0,2"/>
                
                <TextBlock Text="Export" Foreground="Gray" Margin="0,10,0,5"/>
                <Button Content="Export CSV" Command="{Binding AddExportCsvCommand}" Margin="0,2"/>
                <Button Content="Export JSON" Command="{Binding AddExportJsonCommand}" Margin="0,2"/>
                
                <TextBlock Text="Outputs" Foreground="Gray" Margin="0,10,0,5"/>
                <Button Content="Result Table" Command="{Binding AddResultTableCommand}" Margin="0,2"/>
                
                <Border Height="1" Background="Gray" Margin="0,15"/>
                <Button Content="Execute Workflow" Command="{Binding ExecuteWorkflowCommand}" Classes="accent" Margin="0,5"/>
                <Border Height="1" Background="Gray" Margin="0,10"/>
                
                <TextBlock Text="Workflow" Foreground="Gray" Margin="0,5"/>
                <Button Content="Save Workflow" Command="{Binding SaveWorkflowCommand}" Margin="0,2"/>
                <Button Content="Load Workflow" Command="{Binding LoadWorkflowCommand}" Margin="0,2"/>
                            
            </StackPanel>
        </Border>

        <!-- 中間：Canvas -->
        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="4" ClipToBounds="True">
            <Canvas x:Name="MainCanvas" Width="3000" Height="2000" Background="Transparent"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    PointerMoved="Canvas_PointerMoved" PointerReleased="Canvas_PointerReleased">

                <!-- 連線層由 code-behind 直接同步到 Canvas -->
                <Canvas x:Name="EdgeLayer" Width="3000" Height="2000" Background="Transparent"/>
                
                <!-- 暫存連線 -->
                <Path Data="{Binding TempEdgePath}" Stroke="#FFA500" StrokeThickness="3" StrokeDashArray="4,4" Fill="Transparent"/>

                <!-- 節點層由 code-behind 直接同步到 Canvas，避免 ItemsControl container 定位失效 -->
                <Canvas x:Name="NodeLayer" Width="3000" Height="2000" Background="Transparent"/>
            </Canvas>
        </Border>

        <!-- 右側：Inspector & Results -->
        <Border Grid.Column="2" Background="#252526" Margin="5,0,0,0">
            <Grid RowDefinitions="*,Auto,150">
                <Border Grid.Row="0" Margin="10,10,10,5" CornerRadius="4" Background="#1E1E1E">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="Inspector" FontWeight="Bold" Foreground="White" Margin="10"/>
                        <TextBlock Grid.Row="0" Text="{Binding SelectedFile.FileName}" HorizontalAlignment="Right" Margin="10" Foreground="Gray"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding SelectedFileMetadata}" Margin="10,0,10,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding FieldName}" FontWeight="Bold" Foreground="#007ACC" FontSize="12"/>
                                        <TextBlock Text="{Binding ValueText}" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Height="1" Background="Gray" Margin="10,0"/>

                <Border Grid.Row="2" Margin="10,5,10,10" CornerRadius="4" Background="#1E1E1E">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="Results" FontWeight="Bold" Foreground="White" Margin="10"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding ResultFiles}" Margin="10,0,10,10"
                                 SelectionChanged="ResultList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" Foreground="White"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
