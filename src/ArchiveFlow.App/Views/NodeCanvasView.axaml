<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:views="using:ArchiveFlow.App.Views"
             x:Class="ArchiveFlow.App.Views.NodeCanvasView"
             x:DataType="vm:NodeCanvasViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="10">
            <Button Content="Execute Workflow" 
                    Command="{Binding ExecuteWorkflowCommand}"
                    IsEnabled="{Binding !IsExecuting}"
                    Classes="accent"/>
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsExecuting}" 
                         Width="100" 
                         VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Canvas Area -->
        <Border Grid.Row="1" Background="#1E1E1E" Margin="10" CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Nodes}">
                    <!-- Use Canvas as the panel -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="2000" Height="1000" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <!-- Position each item on the Canvas -->
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter" x:DataType="vm:NodeViewModel">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.Styles>

                    <!-- The template for each node -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NodeViewModel">
                            <views:NodeView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Execution Log -->
        <Border Grid.Row="2" Background="#252526" Margin="10,0,10,10" CornerRadius="4" Height="150">
            <TextBox Text="{Binding ExecutionLog}" 
                     IsReadOnly="True" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#00FF00"
                     FontFamily="Consolas, Courier New, monospace"/>
        </Border>
    </Grid>
</UserControl>