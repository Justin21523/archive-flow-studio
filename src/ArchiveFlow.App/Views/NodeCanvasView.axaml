<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:views="using:ArchiveFlow.App.Views"
             x:Class="ArchiveFlow.App.Views.NodeCanvasView"
             x:DataType="vm:NodeCanvasViewModel">

    <Grid ColumnDefinitions="300,*,340" RowDefinitions="Auto,*">
        <Border Grid.ColumnSpan="3"
                Grid.Row="0"
                Background="#252526"
                Padding="12">
            <!-- tool bar -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <StackPanel>
                    <TextBlock Text="Node Workspace"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusMessage}"
                            Foreground="#AAAAAA"
                            FontSize="12"
                            Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Reset + Generate Mock Data"
                        Command="{Binding ResetAndGenerateMockDataCommand}"
                        Margin="0,0,8,0"
                        Padding="12,6"/>

                <Button Grid.Column="2"
                        Content="Execute Workflow"
                        Command="{Binding ExecuteWorkflowCommand}"
                        Margin="0,0,8,0"
                        Padding="12,6"/>

                <Button Grid.Column="3"
                        Content="Apply Pending Changes"
                        Command="{Binding ApplyPendingChangesCommand}"
                        IsEnabled="{Binding HasPendingChanges}"
                        Margin="0,0,8,0"
                        Padding="12,6"/>

                <Button Grid.Column="4"
                        Content="Discard Preview"
                        Command="{Binding DiscardPendingChangesCommand}"
                        IsEnabled="{Binding HasPendingChanges}"
                        Margin="0,0,8,0"
                        Padding="12,6"/>

                <Button Grid.Column="5"
                        Content="Delete Node"
                        Command="{Binding DeleteSelectedNodeCommand}"
                        IsEnabled="{Binding HasSelectedNode}"
                        Margin="0,0,8,0"
                        Padding="12,6"/>

                <Button Grid.Column="6"
                        Content="Delete Connection"
                        Command="{Binding DeleteSelectedEdgeCommand}"
                        IsEnabled="{Binding HasSelectedEdge}"
                        Margin="0,0,8,0"
                        Padding="12,6"/>

                <Button Grid.Column="7"
                        Content="Clear Canvas"
                        Command="{Binding ClearCanvasCommand}"
                        Padding="12,6"/>
            </Grid>
        </Border>

        <!-- Node Library -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#202020"
                BorderBrush="#333333"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Node Library"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="16,14,16,10"/>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding NodeLibraryCategories}"
                                  Margin="12,0,12,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NodeLibraryCategoryViewModel">
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#FFFFFF"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Margin="0,8,0,8"/>

                                    <ItemsControl ItemsSource="{Binding Subcategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:NodeLibrarySubcategoryViewModel">
                                                <StackPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#888888"
                                                               FontSize="11"
                                                               Margin="4,0,0,4"/>

                                                    <ItemsControl ItemsSource="{Binding Nodes}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:NodeLibraryItemViewModel">
                                                                <Button HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Stretch"
                                                                        Margin="0,2"
                                                                        Padding="0"
                                                                        Background="#2D2D30"
                                                                        BorderBrush="#3A3A3D"
                                                                        BorderThickness="1"
                                                                        Tag="{Binding Definition}"
                                                                        Click="AddNodeButton_Click">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                                          Margin="8,7">
                                                                        <TextBlock Text="{Binding Icon}"
                                                                                   Foreground="#CCCCCC"
                                                                                   Width="22"
                                                                                   VerticalAlignment="Top"/>

                                                                        <StackPanel Grid.Column="1">
                                                                            <TextBlock Text="{Binding DisplayName}"
                                                                                       Foreground="White"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding Description}"
                                                                                       Foreground="#888888"
                                                                                       FontSize="10"
                                                                                       TextWrapping="Wrap"
                                                                                       MaxHeight="30"/>
                                                                        </StackPanel>

                                                                        <Border Grid.Column="2"
                                                                                Background="{Binding BadgeBrush}"
                                                                                CornerRadius="3"
                                                                                Padding="5,2"
                                                                                Margin="8,0,0,0"
                                                                                VerticalAlignment="Top">
                                                                            <TextBlock Text="{Binding BadgeText}"
                                                                                       Foreground="White"
                                                                                       FontSize="9"
                                                                                       FontWeight="Bold"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Canvas -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#1E1E1E">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="WorkspaceCanvas"
                        Width="2600"
                        Height="1500"
                        Background="Transparent"
                        PointerPressed="WorkspaceCanvas_PointerPressed"
                        PointerMoved="WorkspaceCanvas_PointerMoved"
                        PointerReleased="WorkspaceCanvas_PointerReleased">

                    <ItemsControl ItemsSource="{Binding Edges}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="2600" Height="1500"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:EdgeViewModel">
                                <Path Data="{Binding PathData}"
                                      Stroke="{Binding StrokeBrush}"
                                      StrokeThickness="{Binding StrokeThickness}"
                                      Fill="Transparent"
                                      PointerPressed="Edge_PointerPressed"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Path Data="{Binding TempConnectionPath}"
                          Stroke="#FFA500"
                          StrokeThickness="3"
                          StrokeDashArray="4,4"
                          Fill="Transparent"/>

                    <ItemsControl ItemsSource="{Binding Nodes}"
                                  x:CompileBindings="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="2600" Height="1500"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.Styles>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NodeInstanceViewModel">
                                <views:NodeView/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </ScrollViewer>
        </Border>

       <!-- Inspector + Results -->
       <Border Grid.Row="1"
            Grid.Column="2"
            Background="#252526"
            BorderBrush="#333333"
            BorderThickness="1,0,0,0">
         <Grid RowDefinitions="*,260">
            <ScrollViewer Grid.Row="0">
                <StackPanel Margin="16">
                    <TextBlock Text="Node Inspector"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Margin="0,0,0,14"/>

                    <!-- Node Summary -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="1. Node Summary"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding InspectorTitle}"
                                    Foreground="White"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding InspectorDescription}"
                                    Foreground="#CCCCCC"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Margin="0,8,0,0"/>

                            <Grid ColumnDefinitions="110,*"
                                RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                Margin="0,12,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Node Type" Foreground="#888888"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InspectorType}" Foreground="White" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Category" Foreground="#888888" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InspectorCategory}" Foreground="White" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Subcategory" Foreground="#888888" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding InspectorSubcategory}" Foreground="White" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Mode" Foreground="#888888" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding InspectorMode}" Foreground="White" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Ports" Foreground="#888888" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding InspectorPorts}" Foreground="White" Margin="0,8,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Dynamic Parameters -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="2. Parameters"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding InspectorParameterSummary}"
                                    Foreground="#AAAAAA"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding InspectorParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NodeParameterInstanceViewModel">
                                        <Border Background="#2D2D30"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                            Text="{Binding DisplayName}"
                                                            Foreground="White"
                                                            FontWeight="SemiBold"
                                                            FontSize="12"/>

                                                    <TextBlock Grid.Column="1"
                                                            Text="{Binding RequiredBadge}"
                                                            Foreground="#888888"
                                                            FontSize="10"/>
                                                </Grid>

                                                <TextBlock Text="{Binding Key}"
                                                        Foreground="#777777"
                                                        FontSize="10"
                                                        Margin="0,2,0,6"/>

                                                <!-- Text and Date parameters -->
                                                <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                        IsVisible="{Binding IsTextLike}"
                                                        Background="#1E1E1E"
                                                        Foreground="White"
                                                        BorderBrush="#444444"
                                                        BorderThickness="1"
                                                        Padding="8,6"
                                                        PlaceholderText="Enter value"/>

                                                <!-- Number parameters -->
                                                <NumericUpDown Value="{Binding NumericValue, Mode=TwoWay}"
                                                            IsVisible="{Binding IsNumber}"
                                                            Background="#1E1E1E"
                                                            Foreground="White"
                                                            BorderBrush="#444444"
                                                            BorderThickness="1"
                                                            Minimum="0"
                                                            Maximum="1000000000"
                                                            Increment="1"/>

                                                <!-- Dropdown parameters -->
                                                <ComboBox ItemsSource="{Binding Options}"
                                                        SelectedItem="{Binding Value, Mode=TwoWay}"
                                                        IsVisible="{Binding IsDropdown}"
                                                        Background="#1E1E1E"
                                                        Foreground="White"
                                                        BorderBrush="#444444"
                                                        BorderThickness="1"
                                                        Padding="8,6"/>

                                                <!-- Boolean parameters -->
                                                <CheckBox IsChecked="{Binding BooleanValue, Mode=TwoWay}"
                                                        IsVisible="{Binding IsBoolean}"
                                                        Foreground="White"
                                                        Content="Enabled"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Preview -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="3. Preview"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding InspectorPreviewTitle}"
                                    Foreground="#4FC3F7"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    Margin="0,0,0,6"/>

                            <TextBox Text="{Binding InspectorPreviewSummary}"
                                    IsReadOnly="True"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    Background="#111111"
                                    Foreground="#CCCCCC"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    MinHeight="90"/>
                        </StackPanel>
                    </Border>

                    <!-- Query / Operation -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="4. Query / Operation"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding InspectorQueryOrOperationTitle}"
                                    Foreground="#4FC3F7"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    Margin="0,0,0,6"/>

                            <TextBox Text="{Binding InspectorQueryOrOperationText}"
                                    IsReadOnly="True"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    Background="#111111"
                                    Foreground="#8BC34A"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    MinHeight="120"/>
                        </StackPanel>
                    </Border>

                    <!-- Warnings -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="5. Warnings / Logs"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBox Text="{Binding InspectorWarnings}"
                                    IsReadOnly="True"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    Background="#111111"
                                    Foreground="#FFC107"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    MinHeight="90"/>
                        </StackPanel>
                    </Border>
                    <!-- Selected File Metadata Entry -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Selected File"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding SelectedFileSummary}"
                                    Foreground="White"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,12"/>

                            <Button Content="Open Metadata Editor"
                                    Command="{Binding OpenMetadataEditorCommand}"
                                    IsEnabled="{Binding HasSelectedFile}"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,8"
                                    Margin="0,0,0,12"/>

                            <TextBlock Text="Metadata Preview"
                                    Foreground="#888888"
                                    FontSize="11"
                                    Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding SelectedFileMetadata}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2D2D30"
                                                CornerRadius="6"
                                                Padding="8"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="120,*">
                                                <TextBlock Grid.Column="0"
                                                        Text="{Binding DisplayName}"
                                                        Foreground="#4FC3F7"
                                                        FontSize="11"
                                                        TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="1"
                                                        Text="{Binding ValueText}"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>                    
                    <!-- Pending Changes -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                        Text="Pending Changes"
                                        Foreground="#BBBBBB"
                                        FontWeight="Bold"
                                        FontSize="12"
                                        Margin="0,0,0,10"/>

                                <TextBlock Grid.Column="1"
                                        Text="{Binding PendingChanges.Count}"
                                        Foreground="#FFC107"
                                        FontWeight="Bold"
                                        FontSize="12"/>
                            </Grid>

                            <TextBlock Text="Action nodes only generate preview changes. Nothing is written until Apply Pending Changes is clicked."
                                    Foreground="#888888"
                                    FontSize="11"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,10"/>

                            <ListBox ItemsSource="{Binding PendingChanges}"
                                    Background="#111111"
                                    BorderThickness="0"
                                    MaxHeight="260">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PendingChangeViewModel">
                                        <Border Background="#2D2D30"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                            Text="{Binding FileName}"
                                                            Foreground="White"
                                                            FontWeight="SemiBold"
                                                            FontSize="12"
                                                            TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Grid.Column="1"
                                                            Text="{Binding Status}"
                                                            Foreground="#FFC107"
                                                            FontSize="11"
                                                            Margin="8,0,0,0"/>
                                                </Grid>

                                                <TextBlock Text="{Binding SourceNodeTitle}"
                                                        Foreground="#4FC3F7"
                                                        FontSize="11"
                                                        Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding ChangeKind}"
                                                        Foreground="#AAAAAA"
                                                        FontSize="11"
                                                        Margin="0,4,0,0"/>

                                                <Grid ColumnDefinitions="70,*,70,*"
                                                    Margin="0,6,0,0">
                                                    <TextBlock Grid.Column="0"
                                                            Text="Old"
                                                            Foreground="#777777"
                                                            FontSize="10"/>

                                                    <TextBlock Grid.Column="1"
                                                            Text="{Binding OldValue}"
                                                            Foreground="#CCCCCC"
                                                            FontSize="10"
                                                            TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Grid.Column="2"
                                                            Text="New"
                                                            Foreground="#777777"
                                                            FontSize="10"
                                                            Margin="8,0,0,0"/>

                                                    <TextBlock Grid.Column="3"
                                                            Text="{Binding NewValue}"
                                                            Foreground="#8BC34A"
                                                            FontSize="10"
                                                            TextTrimming="CharacterEllipsis"/>
                                                </Grid>

                                                <TextBlock Text="{Binding SafetyLevel}"
                                                        Foreground="#888888"
                                                        FontSize="10"
                                                        Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                    <!-- Execution Log -->
                    <Border Background="#1E1E1E"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Execution Log"
                                    Foreground="#BBBBBB"
                                    FontWeight="Bold"
                                    FontSize="12"
                                    Margin="0,0,0,10"/>

                            <TextBox Text="{Binding ExecutionLog}"
                                    IsReadOnly="True"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    Background="#111111"
                                    Foreground="#8BC34A"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    MinHeight="130"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Result Files -->
            <Border Grid.Row="1"
                    Background="#1E1E1E"
                    BorderBrush="#333333"
                    BorderThickness="0,1,0,0"
                    Padding="12">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Result Files"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1"
                            ItemsSource="{Binding ResultFiles}"
                            SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                            Background="#111111"
                            BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="140,*,70"
                                    Margin="6">
                                    <TextBlock Grid.Column="0"
                                            Text="{Binding ArchiveId}"
                                            Foreground="#4FC3F7"
                                            FontSize="11"
                                            TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="1"
                                            Text="{Binding FileName}"
                                            Foreground="White"
                                            FontSize="11"
                                            TextTrimming="CharacterEllipsis"
                                            Margin="8,0"/>

                                    <TextBlock Grid.Column="2"
                                            Text="{Binding FileExtension}"
                                            Foreground="#AAAAAA"
                                            FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
         </Grid>
      </Border>
    </Grid>
</UserControl>
