<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.App.ViewModels"
             xmlns:conv="using:ArchiveFlow.App.Converters"
             x:Class="ArchiveFlow.App.Views.GraphExplorerView"
             x:DataType="vm:GraphExplorerViewModel">

    <Grid ColumnDefinitions="300,*">
        <!-- Left: File Selector -->
        <Border Grid.Column="0" Background="#252526" Margin="10">
            <Grid RowDefinitions="Auto,Auto,*">
                <StackPanel Margin="15">
                    <TextBlock Text="Knowledge Graph Explorer" FontWeight="Bold" Foreground="White" FontSize="16" Margin="0,0,0,15"/>
                    <TextBlock Text="Select a file to explore relationships:" Foreground="Gray" Margin="0,0,0,10"/>
                    <Button Content="Refresh File List" Command="{Binding LoadDataCommand}" Classes="accent" HorizontalAlignment="Stretch" Margin="0,0,0,15"/>
                </StackPanel>

                <!-- 修正：ListBox 必須綁定 SelectedItem 才能觸發 ViewModel 更新 -->
                <ListBox Grid.Row="2" 
                         ItemsSource="{Binding AvailableFiles}" 
                         SelectedItem="{Binding SelectedFile}"
                         Margin="15,0,15,15"
                         Background="#1E1E1E"
                         CornerRadius="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" Foreground="White" TextTrimming="CharacterEllipsis" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Graph Canvas -->
        <Border Grid.Column="1" Background="#1E1E1E" Margin="0,10,10,10" CornerRadius="4" ClipToBounds="True">
            <Grid>
                <!-- 連線層 (獨立 ItemsControl 確保在節點下方) -->
                <ItemsControl ItemsSource="{Binding GraphEdges}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="1000" Height="800" Background="Transparent"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GraphEdgeViewModel">
                            <!-- 使用 Path 繪製曲線，比 Line 更美觀 -->
                            <Path Data="{Binding PathData}" 
                                  Stroke="#007ACC" 
                                  StrokeThickness="2" 
                                  Opacity="0.6"
                                  Fill="Transparent"
                                  ZIndex="1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 使用 ItemsControl 的 Canvas 面板來確保絕對定位生效 -->
                <ItemsControl ItemsSource="{Binding GraphNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="1000" Height="800" Background="Transparent"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GraphNodeViewModel">
                            <!-- 節點渲染 -->
                            <Border Width="120" Height="40" 
                                    CornerRadius="20" 
                                    Background="{Binding IsCenter, Converter={x:Static conv:BoolToBrushConverter.Instance}}"
                                    BorderBrush="#007ACC" BorderThickness="2"
                                    Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                                    BoxShadow="0 4 6 rgba(0,0,0,0.5)"
                                    ZIndex="10">
                                <TextBlock Text="{Binding Label}" 
                                           Foreground="White" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="5"
                                           FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
