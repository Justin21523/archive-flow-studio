<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.Browser.ViewModels"
             x:Class="ArchiveFlow.Browser.Views.MainView">
    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#B8B8B8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#393939"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Padding" Value="10,7"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,220"
          Background="#1E1E1E">
        <Border Grid.Row="0"
                Background="#202022"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="ArchiveFlow Studio"
                               Foreground="White"
                               FontSize="23"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding DemoNotice}"
                               Foreground="#D6C48B"
                               TextWrapping="Wrap"
                               MaxWidth="1000"/>
                    <TextBlock Text="{Binding DesktopNotice}"
                               Foreground="#9BC7FF"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Scenarios}"
                              SelectedItem="{Binding SelectedScenario}"
                              Width="210"/>
                    <Button Content="Load Scenario"
                            Command="{Binding LoadScenarioCommand}"/>
                    <Button Content="Reset Demo"
                            Command="{Binding ResetDemoDataCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="250,*,340"
              ColumnSpacing="12"
              Margin="14">
            <Border Classes="panel"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Margin="12"
                                Spacing="4">
                        <TextBlock Text="Node Library"
                                   Classes="section-title"/>
                        <TextBlock Text="Click to add nodes. Select a node to connect, group, resize, duplicate, or delete."
                                   Classes="muted"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding NodeLibraryGroups}"
                                      Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserNodeLibraryGroup">
                                    <StackPanel Spacing="8"
                                                Margin="0,0,0,16">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#9BC7FF"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding Nodes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:BrowserNodeLibraryItem">
                                                    <Button Tag="{Binding}"
                                                            Click="AddNodeButton_Click"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            Background="#1E1E1E"
                                                            BorderBrush="#343434"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="9,7"
                                                            Margin="0,0,0,6">
                                                        <Grid ColumnDefinitions="8,*"
                                                              ColumnSpacing="8">
                                                            <Border Width="8"
                                                                    Height="28"
                                                                    CornerRadius="3"
                                                                    Background="{Binding Color}"/>
                                                            <StackPanel Grid.Column="1"
                                                                        Spacing="2">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="#F4F4F4"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Kind}"
                                                                           Classes="muted"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  RowSpacing="10">
                <Border Classes="panel">
                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,150"
                          RowSpacing="8"
                          ColumnSpacing="10">
                        <TextBox PlaceholderText="Search filename, path, metadata, or preview text"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 MinWidth="280"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ExtensionFilters}"
                                  SelectedItem="{Binding SelectedExtensionFilter}"/>
                        <WrapPanel Grid.Row="1"
                                   Grid.ColumnSpan="2">
                            <Button Content="Run"
                                    Command="{Binding ExecuteWorkflowCommand}"/>
                            <Button Content="Add Link Source"
                                    Command="{Binding MarkConnectionSourceCommand}"/>
                            <Button Content="Connect"
                                    Command="{Binding ConnectToSelectedNodeCommand}"/>
                            <Button Content="Delete Link"
                                    Command="{Binding DeleteSelectedConnectionCommand}"/>
                            <Button Content="Duplicate"
                                    Command="{Binding DuplicateSelectedNodeCommand}"/>
                            <Button Content="Delete Node"
                                    Command="{Binding DeleteSelectedNodeCommand}"/>
                            <Button Content="Group"
                                    Command="{Binding CreateGroupFromSelectedNodeCommand}"/>
                            <Button Content="Clear Groups"
                                    Command="{Binding ClearGroupsCommand}"/>
                            <Button Content="Bigger"
                                    Command="{Binding GrowSelectedNodeCommand}"/>
                            <Button Content="Smaller"
                                    Command="{Binding ShrinkSelectedNodeCommand}"/>
                            <Button Content="Reset Flow"
                                    Command="{Binding ResetWorkflowCommand}"/>
                            <Button Content="Reset View"
                                    Command="{Binding ResetCanvasViewCommand}"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#151515"
                        BorderBrush="#333333"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <Grid x:Name="WorkspaceSurface"
                          Background="#171717"
                          PointerPressed="WorkspaceCanvas_PointerPressed"
                          PointerMoved="WorkspaceCanvas_PointerMoved"
                          PointerReleased="WorkspaceCanvas_PointerReleased"
                          PointerWheelChanged="WorkspaceCanvas_PointerWheelChanged">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding CanvasZoom}"
                                                ScaleY="{Binding CanvasZoom}"/>
                                <TranslateTransform X="{Binding CanvasOffsetX}"
                                                    Y="{Binding CanvasOffsetY}"/>
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <ItemsControl ItemsSource="{Binding WorkflowEdges}"
                                      Width="1500"
                                      Height="900"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="1500" Height="900"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserWorkflowEdge">
                                    <Path Data="{Binding PathData}"
                                          Stroke="#74B6D8"
                                          StrokeThickness="3"
                                          Fill="Transparent"
                                          PointerPressed="WorkflowEdge_PointerPressed"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding WorkflowGroups}"
                                      Width="1500"
                                      Height="900"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="1500" Height="900"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserWorkflowGroup">
                                    <Border Width="{Binding Width}"
                                            Height="{Binding Height}"
                                            Background="#223B4A5E"
                                            BorderBrush="#7FC4E4"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#CFEFFF"
                                                   FontWeight="SemiBold"
                                                   Margin="12,8"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding WorkflowNodes}"
                                      Width="1500"
                                      Height="900"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      x:CompileBindings="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="1500" Height="900"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserWorkflowNode">
                                    <Grid Width="{Binding Width}"
                                          Height="{Binding Height}"
                                          PointerPressed="WorkflowNode_PointerPressed">
                                        <Border Background="{Binding Color}"
                                                BorderBrush="#DDEEFF"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="12">
                                            <Grid RowDefinitions="Auto,*,Auto">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="6">
                                                    <TextBlock Text="{Binding Icon}"
                                                               Foreground="#FFFFFF"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Kind}"
                                                               Foreground="#DCEEFF"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Grid>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Title}"
                                                           Foreground="White"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding OutputLabel}"
                                                           Foreground="#F1F1F1"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="30"/>
                                            </Grid>
                                        </Border>

                                        <Border Width="16"
                                                Height="16"
                                                CornerRadius="8"
                                                Background="#F4F7FF"
                                                BorderBrush="#1A1A1A"
                                                BorderThickness="2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Margin="-8,0,0,0"
                                                IsVisible="{Binding CanAcceptInput}"
                                                PointerPressed="InputPort_PointerPressed"/>
                                        <Border Width="16"
                                                Height="16"
                                                CornerRadius="8"
                                                Background="#FFE18A"
                                                BorderBrush="#1A1A1A"
                                                BorderThickness="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,-8,0"
                                                IsVisible="{Binding CanStartOutput}"
                                                PointerPressed="OutputPort_PointerPressed"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Background="#D0222222"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="12">
                            <TextBlock Text="Drag nodes | Middle-drag to pan | Mouse wheel to zoom"
                                       Foreground="#CFCFCF"
                                       FontSize="11"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="2">
                <StackPanel Spacing="12">
                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding InspectorTitle}"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding SelectedNodeKind}"
                                       Foreground="#9BC7FF"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding InspectorDescription}"
                                       Foreground="#D8D8D8"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedNodeOutput}"
                                       Foreground="#8BC34A"
                                       TextWrapping="Wrap"/>
                            <ItemsControl ItemsSource="{Binding SelectedWorkflowNode.Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:BrowserNodeParameter">
                                        <Grid RowDefinitions="Auto,Auto"
                                              Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#9BC7FF"
                                                       FontWeight="SemiBold"/>
                                            <TextBox Grid.Row="1"
                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     IsVisible="{Binding IsText}"
                                                     MinHeight="32"/>
                                            <TextBox Grid.Row="1"
                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     IsVisible="{Binding IsNumber}"
                                                     MinHeight="32"/>
                                            <TextBox Grid.Row="1"
                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     IsVisible="{Binding IsDate}"
                                                     PlaceholderText="YYYY-MM-DD"
                                                     MinHeight="32"/>
                                            <ComboBox Grid.Row="1"
                                                      ItemsSource="{Binding Options}"
                                                      SelectedItem="{Binding Value, Mode=TwoWay}"
                                                      IsVisible="{Binding IsDropdown}"
                                                      MinHeight="32"/>
                                            <CheckBox Grid.Row="1"
                                                      Content="Enabled"
                                                      IsChecked="{Binding Value, Mode=TwoWay}"
                                                      IsVisible="{Binding IsCheckbox}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Workflow Status"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding WorkflowSummary}"
                                       Foreground="#EDEDED"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       Foreground="#D6C48B"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#8BC34A"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Selected File"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding SelectedFile.FileName}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFile.Preview}"
                                       Foreground="#CFCFCF"
                                       TextWrapping="Wrap"/>
                            <ItemsControl ItemsSource="{Binding SelectedMetadata}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="95,*"
                                              Margin="0,4,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#9BC7FF"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ValueText}"
                                                       Foreground="#EDEDED"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Mock Import"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding ImportSummary}"
                                       Classes="muted"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Preview"
                                        Command="{Binding PreviewImportCommand}"/>
                                <Button Content="Confirm"
                                        Command="{Binding ConfirmImportCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Classes="panel"
                Margin="14,0,14,14"
                Padding="0">
            <TabControl>
                <TabItem Header="Results">
                    <Grid ColumnDefinitions="2*,1.1*,1.2*"
                          ColumnSpacing="12"
                          Margin="12">
                        <Grid RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <TextBlock Text="{Binding FilteredCount, StringFormat='Result Table ({0} files)'}"
                                           Classes="section-title"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <ComboBox ItemsSource="{Binding ExportFormats}"
                                              SelectedItem="{Binding SelectedExportFormat}"
                                              Width="145"/>
                                    <Button Content="Export"
                                            Command="{Binding ExportFilteredCommand}"/>
                                </StackPanel>
                            </Grid>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding FilteredFiles}"
                                     SelectedItem="{Binding SelectedFile}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:BrowserFileRow">
                                        <Grid ColumnDefinitions="2*,90,110"
                                              ColumnSpacing="10"
                                              Margin="0,5">
                                            <StackPanel>
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Path}"
                                                           Classes="muted"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Extension}"
                                                       Foreground="#9BC7FF"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Size}"
                                                       Foreground="#CFCFCF"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding PendingChanges.Count, StringFormat='Pending Changes ({0})'}"
                                           Classes="section-title"/>
                                <Button Grid.Column="1"
                                        Content="Apply"
                                        Command="{Binding ApplyPendingChangesCommand}"/>
                            </Grid>
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding PendingChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:BrowserPendingChange">
                                            <Grid ColumnDefinitions="*,90"
                                                  Margin="0,4,0,0">
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           Foreground="#D6C48B"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Spacing="8">
                            <TextBlock Text="Export Preview"
                                       Classes="section-title"/>
                            <TextBox Text="{Binding ExportPreview}"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     MinHeight="120"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Relationships">
                    <Grid ColumnDefinitions="340,*"
                          ColumnSpacing="16"
                          Margin="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Create Relationship"
                                       Classes="section-title"/>
                            <ComboBox ItemsSource="{Binding FilteredFiles}"
                                      SelectedItem="{Binding SourceFile}"/>
                            <ComboBox ItemsSource="{Binding FilteredFiles}"
                                      SelectedItem="{Binding TargetFile}"/>
                            <ComboBox ItemsSource="{Binding RelationshipTypes}"
                                      SelectedItem="{Binding SelectedRelationshipType}"/>
                            <Button Content="Create Relationship"
                                    Command="{Binding CreateRelationshipCommand}"/>
                        </StackPanel>

                        <ListBox Grid.Column="1"
                                 ItemsSource="{Binding Relationships}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*,130,2*,140"
                                          ColumnSpacing="10"
                                          Margin="0,5">
                                        <TextBlock Text="{Binding SourceFileName}"
                                                   Foreground="White"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RelationshipType}"
                                                   Foreground="#D6C48B"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TargetFileName}"
                                                   Foreground="White"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding CreatedAt}"
                                                   Classes="muted"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Import / Jobs">
                    <Grid ColumnDefinitions="1.2*,1*,1*"
                          ColumnSpacing="16"
                          Margin="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Mock Import Preview"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding ImportSummary}"
                                       Classes="muted"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Preview Import"
                                        Command="{Binding PreviewImportCommand}"/>
                                <Button Content="Confirm Import"
                                        Command="{Binding ConfirmImportCommand}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ImportPreviewItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,90"
                                              Margin="0,4,0,0">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="White"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Status}"
                                                       Foreground="#9BC7FF"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <TextBlock Text="Export Jobs"
                                       Classes="section-title"/>
                            <ItemsControl ItemsSource="{Binding ExportJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="90,70,*"
                                              Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Format}"
                                                       Foreground="#9BC7FF"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding FileCount}"
                                                       Foreground="White"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Status}"
                                                       Foreground="#8BC34A"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Spacing="8">
                            <TextBlock Text="Import Jobs"
                                       Classes="section-title"/>
                            <ItemsControl ItemsSource="{Binding ImportJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="80,80,*"
                                              Margin="0,4,0,0">
                                            <TextBlock Text="{Binding ImportedCount}"
                                                       Foreground="#9BC7FF"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ErrorCount}"
                                                       Foreground="#D6C48B"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Status}"
                                                       Foreground="#8BC34A"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
