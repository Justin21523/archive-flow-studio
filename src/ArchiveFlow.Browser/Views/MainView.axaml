<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArchiveFlow.Browser.ViewModels"
             x:Class="ArchiveFlow.Browser.Views.MainView">
    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#B8B8B8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#393939"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Padding" Value="10,7"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,220"
          Background="#1E1E1E">
        <Border Grid.Row="0"
                Background="#202022"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="ArchiveFlow Studio"
                               Foreground="White"
                               FontSize="23"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding DemoNotice}"
                               Foreground="#D6C48B"
                               TextWrapping="Wrap"
                               MaxWidth="1000"/>
                    <TextBlock Text="{Binding DesktopNotice}"
                               Foreground="#9BC7FF"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Scenarios}"
                              SelectedItem="{Binding SelectedScenario}"
                              Width="210"/>
                    <Button Content="Load Scenario"
                            Command="{Binding LoadScenarioCommand}"/>
                    <Button Content="Reset Demo"
                            Command="{Binding ResetDemoDataCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="250,*,340"
              ColumnSpacing="12"
              Margin="14">
            <Border Classes="panel"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Margin="12"
                                Spacing="4">
                        <TextBlock Text="Node Library"
                                   Classes="section-title"/>
                        <TextBlock Text="Browser-safe demo nodes"
                                   Classes="muted"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding NodeLibraryGroups}"
                                      Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserNodeLibraryGroup">
                                    <StackPanel Spacing="8"
                                                Margin="0,0,0,16">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#9BC7FF"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding Nodes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1E1E1E"
                                                            BorderBrush="#343434"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10,7"
                                                            Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="#EDEDED"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  RowSpacing="10">
                <Border Classes="panel">
                    <Grid ColumnDefinitions="*,150,Auto"
                          ColumnSpacing="10">
                        <TextBox PlaceholderText="Search filename, path, metadata, or preview text"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 MinWidth="280"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ExtensionFilters}"
                                  SelectedItem="{Binding SelectedExtensionFilter}"/>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Run Workflow"
                                    Command="{Binding ExecuteWorkflowCommand}"/>
                            <Button Content="Reset View"
                                    Command="{Binding ResetCanvasViewCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#151515"
                        BorderBrush="#333333"
                        BorderThickness="1"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <Grid x:Name="WorkspaceSurface"
                          Background="#171717"
                          PointerPressed="WorkspaceCanvas_PointerPressed"
                          PointerMoved="WorkspaceCanvas_PointerMoved"
                          PointerReleased="WorkspaceCanvas_PointerReleased"
                          PointerWheelChanged="WorkspaceCanvas_PointerWheelChanged">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding CanvasZoom}"
                                                ScaleY="{Binding CanvasZoom}"/>
                                <TranslateTransform X="{Binding CanvasOffsetX}"
                                                    Y="{Binding CanvasOffsetY}"/>
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <ItemsControl ItemsSource="{Binding WorkflowEdges}"
                                      Width="1500"
                                      Height="900"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="1500" Height="900"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserWorkflowEdge">
                                    <Path Data="{Binding PathData}"
                                          Stroke="#74B6D8"
                                          StrokeThickness="3"
                                          Fill="Transparent"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding WorkflowNodes}"
                                      Width="1500"
                                      Height="900"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      x:CompileBindings="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="1500" Height="900"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BrowserWorkflowNode">
                                    <Border Width="{Binding Width}"
                                            Height="{Binding Height}"
                                            Background="#3E6B8C"
                                            BorderBrush="#DDEEFF"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            Padding="12"
                                            PointerPressed="WorkflowNode_PointerPressed">
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <TextBlock Text="{Binding Kind}"
                                                       Foreground="#DCEEFF"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding OutputLabel}"
                                                       Foreground="#F1F1F1"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="30"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Background="#D0222222"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="12">
                            <TextBlock Text="Drag nodes | Middle-drag to pan | Mouse wheel to zoom"
                                       Foreground="#CFCFCF"
                                       FontSize="11"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="2">
                <StackPanel Spacing="12">
                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding InspectorTitle}"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding SelectedNodeKind}"
                                       Foreground="#9BC7FF"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding InspectorDescription}"
                                       Foreground="#D8D8D8"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedNodeOutput}"
                                       Foreground="#8BC34A"
                                       TextWrapping="Wrap"/>
                            <ItemsControl ItemsSource="{Binding SelectedWorkflowNode.Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:BrowserNodeParameter">
                                        <Grid ColumnDefinitions="100,*"
                                              Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#9BC7FF"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Foreground="#EDEDED"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Workflow Status"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding WorkflowSummary}"
                                       Foreground="#EDEDED"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#8BC34A"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Selected File"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding SelectedFile.FileName}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedFile.Preview}"
                                       Foreground="#CFCFCF"
                                       TextWrapping="Wrap"/>
                            <ItemsControl ItemsSource="{Binding SelectedMetadata}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="95,*"
                                              Margin="0,4,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#9BC7FF"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ValueText}"
                                                       Foreground="#EDEDED"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Mock Import"
                                       Classes="section-title"/>
                            <TextBlock Text="{Binding ImportSummary}"
                                       Classes="muted"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Preview"
                                        Command="{Binding PreviewImportCommand}"/>
                                <Button Content="Confirm"
                                        Command="{Binding ConfirmImportCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="2*,1.1*,1.2*"
              ColumnSpacing="12"
              Margin="14,0,14,14">
            <Border Classes="panel"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Margin="12"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <TextBlock Text="{Binding FilteredCount, StringFormat='Result Table ({0} files)'}"
                                   Classes="section-title"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <ComboBox ItemsSource="{Binding ExportFormats}"
                                      SelectedItem="{Binding SelectedExportFormat}"
                                      Width="145"/>
                            <Button Content="Export"
                                    Command="{Binding ExportFilteredCommand}"/>
                        </StackPanel>
                    </Grid>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding FilteredFiles}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:BrowserFileRow">
                                <Grid ColumnDefinitions="2*,90,110"
                                      ColumnSpacing="10"
                                      Margin="12,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path}"
                                                   Classes="muted"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Extension}"
                                               Foreground="#9BC7FF"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Size}"
                                               Foreground="#CFCFCF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Classes="panel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding PendingChanges.Count, StringFormat='Pending Changes ({0})'}"
                                   Classes="section-title"/>
                        <Button Grid.Column="1"
                                Content="Apply"
                                Command="{Binding ApplyPendingChangesCommand}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding PendingChanges}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:BrowserPendingChange">
                                <Grid ColumnDefinitions="*,90"
                                      Margin="0,4,0,0">
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="#D6C48B"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Classes="panel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Export Preview"
                               Classes="section-title"/>
                    <TextBox Text="{Binding ExportPreview}"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             MinHeight="120"
                             TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
